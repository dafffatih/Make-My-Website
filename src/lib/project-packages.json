{
  "forms": [
    {
      "package": "Landing Page",
      "base_price": 500,
      "currency": "USD",
      "sections": [
        {
          "title": "Basic Information",
          "fields": [
            {"label": "Full Name", "type": "short_text"},
            {"label": "Email Address", "type": "short_text"},
            {"label": "Business / Brand Name", "type": "short_text"},
            {"label": "Existing Website or Social Media Link", "type": "short_text"}
          ]
        },
        {
          "title": "Project Goal",
          "fields": [
            {
              "label": "Main Goal",
              "type": "select",
              "options": ["Sell a product", "Generate leads", "Promote a service", "Event / campaign", "Other"]
            },
            {"label": "Goal Description", "type": "long_text"},
            {"label": "Target Audience", "type": "long_text"},
            {"label": "Key Message", "type": "long_text"}
          ]
        },
        {
          "title": "Content Availability",
          "fields": [
            {
              "label": "Available Content",
              "type": "multiselect",
              "options": ["Copywriting", "Images", "Logo", "Branding guidelines"]
            },
            {
              "label": "Need Content Help",
              "type": "select",
              "options": ["Yes", "No"]
            }
          ]
        },
        {
          "title": "Design Preferences",
          "fields": [
            {"label": "Reference Websites", "type": "long_text"},
            {
              "label": "Design Style",
              "type": "multiselect",
              "options": ["Minimalist", "Modern", "Corporate", "Bold / Creative"]
            }
          ]
        },
        {
          "title": "CTA",
          "fields": [
            {
              "label": "Main CTA",
              "type": "select",
              "options": ["Contact form", "WhatsApp", "Email", "Purchase / Checkout"]
            },
            {"label": "Collected Information", "type": "long_text"}
          ]
        },
        {
          "title": "Add-ons",
          "fields": [
            {
              "label": "Additional Features",
              "type": "multiselect",
              "options": [
                {"name": "Extra Section", "price": 50},
                {"name": "Copywriting", "price": 150},
                {"name": "Stock Images", "price": 100},
                {"name": "Advanced Animation", "price": 200},
                {"name": "Multi-language", "price": 250},
                {"name": "WhatsApp Integration", "price": 50},
                {"name": "Email Marketing", "price": 150}
              ]
            }
          ]
        },
        {
          "title": "Timeline",
          "fields": [
            {"label": "Deadline", "type": "date"},
            {
              "label": "Urgency",
              "type": "select",
              "options": [
                {"name": "Standard", "price": 0},
                {"name": "Rush", "price": 200}
              ]
            }
          ]
        },
        {
          "title": "Additional Information",
          "fields": [
            {"label": "Additional Notes", "type": "long_text"},
            {
              "label": "Upload PRD",
              "type": "file",
              "accept": ["pdf", "docx", "png", "jpg"],
              "max_size_mb": 10
            }
          ]
        }
      ]
    },
